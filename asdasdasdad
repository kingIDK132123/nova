    -- ====================== ESP ======================
    local function GetPlayerColor(plr)
        return (UseTeamColor and plr.Team and plr.Team.TeamColor.Color) or ESPColor
    end

    local function CreateESP(plr)
        if plr == LocalPlayer then return end
        local function OnChar(char)
            local root = char:WaitForChild("HumanoidRootPart", 5)
            local head = char:WaitForChild("Head", 5)
            local hum = char:WaitForChild("Humanoid", 5)
            if not root or not head then return end

            local hl = Instance.new("Highlight")
            hl.FillTransparency = 0.7
            hl.OutlineTransparency = 0
            hl.OutlineColor = GetPlayerColor(plr)
            hl.FillColor = GetPlayerColor(plr)
            hl.Adornee = char
            hl.Parent = char
            ESPHighlights[plr] = hl

            local bb = Instance.new("BillboardGui", char)
            bb.Adornee = head
            bb.Size = UDim2.new(5,0,3.5,0)
            bb.StudsOffset = Vector3.new(0,4,0)
            bb.AlwaysOnTop = true

            local nameLabel = Instance.new("TextLabel", bb)
            nameLabel.Size = UDim2.new(1,0,0.4,0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.TextStrokeTransparency = 0
            nameLabel.Font = Enum.Font.GothamBold
            nameLabel.TextSize = 15
            nameLabel.TextColor3 = GetPlayerColor(plr)

            local healthBG = Instance.new("Frame", bb)
            healthBG.Size = UDim2.new(0.85,0,0.18,0)
            healthBG.Position = UDim2.new(0.075,0,0.45,0)
            healthBG.BackgroundColor3 = Color3.new(0,0,0)

            local healthBar = Instance.new("Frame", healthBG)
            healthBar.Size = UDim2.new(1,0,1,0)
            healthBar.BackgroundColor3 = Color3.new(0,1,0)

            local distLabel = Instance.new("TextLabel", bb)
            distLabel.Size = UDim2.new(1,0,0.35,0)
            distLabel.Position = UDim2.new(0,0,0.7,0)
            distLabel.BackgroundTransparency = 1
            distLabel.TextStrokeTransparency = 0
            distLabel.Font = Enum.Font.Gotham
            distLabel.TextSize = 13

            ESPBillboards[plr] = {bb=bb, name=nameLabel, health=healthBar, dist=distLabel}

            local function CreateSkeleton()
                if ESPSkeletonLines[plr] then return end
                local lines = {}
                local parts = {"Head","LeftUpperArm","RightUpperArm","LeftLowerArm","RightLowerArm","LeftHand","RightHand","LeftUpperLeg","RightUpperLeg","LeftLowerLeg","RightLowerLeg","LeftFoot","RightFoot"}
                for i = 1, #parts-1 do
                    local line = Drawing.new("Line")
                    line.Thickness = 2
                    line.Color = GetPlayerColor(plr)
                    lines[parts[i]] = line
                end
                ESPSkeletonLines[plr] = lines
            end
            CreateSkeleton()

            hum.HealthChanged:Connect(function(hp)
                local p = math.clamp(hp/hum.MaxHealth,0,1)
                healthBar.Size = UDim2.new(p,0,1,0)
                nameLabel.Text = plr.Name .. " ["..math.floor(hp).."]"
            end)
        end

        if plr.Character then OnChar(plr.Character) end
        plr.CharacterAdded:Connect(OnChar)
    end

    local function DestroyESP()
        for plr, hl in pairs(ESPHighlights) do if hl then hl:Destroy() end end
        ESPHighlights = {}
        for plr, data in pairs(ESPBillboards) do if data and data.bb then data.bb:Destroy() end end
        ESPBillboards = {}
        for plr, lines in pairs(ESPSkeletonLines) do
            for _, line in pairs(lines) do line:Remove() end
        end
        ESPSkeletonLines = {}
        for _, tracer in pairs(ESPTracers) do tracer:Remove() end
        ESPTracers = {}
    end

    Players.PlayerAdded:Connect(function(plr)
        if ESPEnabled then CreateESP(plr) end
    end)

    RunService.Heartbeat:Connect(function()
        if not ESPEnabled then return end
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end

        for plr, data in pairs(ESPBillboards) do
            local char = plr.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local dist = (myRoot.Position - char.HumanoidRootPart.Position).Magnitude
                data.dist.Text = math.floor(dist) .. " studs"
            end
        end

        for plr, _ in pairs(ESPBillboards) do
            local char = plr.Character
            if char and char:FindFirstChild("Head") then
                if not ESPTracers[plr] then
                    ESPTracers[plr] = Drawing.new("Line")
                    ESPTracers[plr].Thickness = 2
                    ESPTracers[plr].Color = GetPlayerColor(plr)
                end
                local headPos, onScreen = Camera:WorldToViewportPoint(char.Head.Position)
                local myHeadPos = Camera:WorldToViewportPoint(myRoot.Position + Vector3.new(0,2,0))
                if onScreen then
                    ESPTracers[plr].From = Vector2.new(myHeadPos.X, myHeadPos.Y)
                    ESPTracers[plr].To = Vector2.new(headPos.X, headPos.Y)
                    ESPTracers[plr].Visible = TracersEnabled
                else
                    ESPTracers[plr].Visible = false
                end
            end
        end

        for plr, lines in pairs(ESPSkeletonLines) do
            local char = plr.Character
            if char and SkeletonEnabled then
                local function GetPart(partName) return char:FindFirstChild(partName) end
                local connections = {
                    {GetPart("Head"), GetPart("LeftUpperArm")},{GetPart("LeftUpperArm"), GetPart("LeftLowerArm")},
                    {GetPart("LeftLowerArm"), GetPart("LeftHand")},{GetPart("Head"), GetPart("RightUpperArm")},
                    {GetPart("RightUpperArm"), GetPart("RightLowerArm")},{GetPart("RightLowerArm"), GetPart("RightHand")},
                    {GetPart("Head"), GetPart("HumanoidRootPart")},{GetPart("HumanoidRootPart"), GetPart("LeftUpperLeg")},
                    {GetPart("LeftUpperLeg"), GetPart("LeftLowerLeg")},{GetPart("LeftLowerLeg"), GetPart("LeftFoot")},
                    {GetPart("HumanoidRootPart"), GetPart("RightUpperLeg")},{GetPart("RightUpperLeg"), GetPart("RightLowerLeg")},
                    {GetPart("RightLowerLeg"), GetPart("RightFoot")}
                }
                for _, pair in ipairs(connections) do
                    local from, to = pair[1], pair[2]
                    if from and to then
                        local fromPos = Camera:WorldToViewportPoint(from.Position)
                        local toPos = Camera:WorldToViewportPoint(to.Position)
                        local line = lines[from.Name] or lines[to.Name]
                        if line then
                            line.From = Vector2.new(fromPos.X, fromPos.Y)
                            line.To = Vector2.new(toPos.X, toPos.Y)
                            line.Visible = true
                        end
                    end
                end
            else
                for _, line in pairs(lines) do line.Visible = false end
            end
        end
    end)

    -- ====================== ADVANCED FLY ======================
    local function StopAdvancedFly()
        advancedFlyEnabled = false
        if flyConnection then flyConnection:Disconnect() flyConnection = nil end
        if bv then bv:Destroy() bv = nil end
        if bg then bg:Destroy() bg = nil end
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if hum then hum.PlatformStand = false end
            if root then
                root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                root.AssemblyAngularVelocity = Vector3.new(0,0,0)
            end
        end
    end

    local function StartAdvancedFly()
        StopAdvancedFly()
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not root or not hum then return end

        advancedFlyEnabled = true
        hum.PlatformStand = true

        bv = Instance.new("BodyVelocity")
        bv.Name = "NovaFlyBV"
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = Vector3.new(0,0,0)
        bv.Parent = root

        bg = Instance.new("BodyGyro")
        bg.Name = "NovaFlyBG"
        bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.P = 10000
        bg.D = 500
        bg.Parent = root

        flyConnection = RunService.Heartbeat:Connect(function()
            if not advancedFlyEnabled or not root.Parent then StopAdvancedFly() return end
            local dir = Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.new(0,1,0) end

            local spd = flySpeed
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then spd *= 2.5 end

            bv.Velocity = dir.Magnitude > 0 and dir.Unit * spd or Vector3.new(0,0,0)
            bg.CFrame = Camera.CFrame
        end)
    end

